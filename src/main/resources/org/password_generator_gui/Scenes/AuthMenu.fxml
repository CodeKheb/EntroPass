                  </Label>
                  <Label prefHeight="36.0" prefWidth="316.0" text="Welcome back. Please authenticate to access your super very secret data" textAlignment="CENTER" textFill="#c3c3c3" wrapText="true">
                     <font>
                        <Font name="Segoe UI" size="14.0" />
                     </font>
                     <VBox.margin>
                        <Insets bottom="-10.0" />
                     </VBox.margin>
                  </Label>
                  <Group />
                  <Pane prefHeight="111.0" prefWidth="419.0">
