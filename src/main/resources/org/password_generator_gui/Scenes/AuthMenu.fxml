<AnchorPane prefHeight="901.0" prefWidth="1230.0" style="-fx-background-color: gray;" styleClass="root-pane" stylesheets="@../stylesheets/AuthStyleSheet.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="GUI.Controllers.AuthenticatorController">
   <children>
      <BorderPane layoutX="400.0" layoutY="155.0" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="592.0" prefWidth="431.0" styleClass="auth-box" stylesheets="@../stylesheets/AuthStyleSheet.css">
         <center>
            <VBox alignment="TOP_CENTER" prefHeight="200.0" prefWidth="100.0" spacing="20.0" BorderPane.alignment="CENTER">
               <children>
                  <Group>
                     <children>
                        <Circle fill="#6dab5d" radius="33.0" stroke="WHITE" strokeLineCap="ROUND" strokeType="INSIDE" strokeWidth="0.0" />
                        <ImageView fitHeight="78.0" fitWidth="79.0" layoutX="-39.0" layoutY="-39.0" pickOnBounds="true" preserveRatio="true">
                           <image>
                              <Image url="@../Icons/Images/FingerPrint.png" />
                           </image>
                        </ImageView>
                     </children>
                  </Group>
                  <Label text="Unlock Vault" textFill="WHITE">
                     <font>
                        <Font name="Segoe UI Bold" size="20.0" />
