                        <Label layoutX="21.0" text="MASTER PASSWORD">
                           <font>
                              <Font name="Segoe UI Bold" size="12.0" />
                           </font>
                        </Label>
                        <CheckBox alignment="CENTER" contentDisplay="TOP" graphicTextGap="6.0" layoutX="20.0" layoutY="81.0" mnemonicParsing="false" text="Remember session" textFill="#c3c3c3" />
                        <PasswordField fx:id="AuthTextField" layoutX="20.0" layoutY="24.0" prefHeight="54.0" prefWidth="391.0" promptText="Enter your key">
